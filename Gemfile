source "https://rubygems.org"

ruby "3.3.5"

# server.rb uses several libraries that were removed from Ruby's default gems.
# Pin each so Bundler installs them explicitly.
gem "webrick", "~> 1.8"    # removed from defaults in Ruby 3.0+
gem "net-smtp", "~> 0.5"   # removed from defaults in Ruby 3.1+
gem "csv", "~> 3.3"        # removed from defaults in Ruby 3.4+
gem "ostruct", "~> 0.6"    # removed from defaults in Ruby 3.5+
